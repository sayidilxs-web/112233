{
  "name": "shadowrecon-ultimate",
  "productName": "ShadowRecon Ultimate",
  "version": "7.7.7",
  "description": "Advanced cyber research and monitoring platform.",
  "main": "main.js",
  "author": {
    "name": "ShadowRecon Labs",
    "email": "shadowrecon@local"
  },
  "license": "MIT",
  "private": true,

  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "pack": "electron-builder --dir",
    "clean": "rimraf dist reports logs tools captures"
  },

  "dependencies": {
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "axios": "^1.7.9",
    "extract-zip": "^2.0.1",
    "node-notifier": "^10.0.1",
    "screenshot-desktop": "^1.15.0",
    "tesseract.js": "^5.1.0",
    "@nut-tree/nut-js": "^3.1.1"
  },

  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "rimraf": "^6.0.1"
  },

  "build": {
    "appId": "com.shadowrecon.ultimate",
    "productName": "ShadowRecon Ultimate",

    "directories": {
      "output": "dist"
    },

    "files": [
      "**/*",
      "!dist/**",
      "!reports/**",
      "!logs/**",
      "!tools/**",
      "!captures/**"
    ],

    "asar": true,

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },

    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development",
      "icon": "assets/icon.png"
    },

    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools"
    },

    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ShadowRecon Ultimate"
    }
  }
}
